<%
// Load wallpaper data — Bing from posts, Pexels from JSON
var wallpaperImages = [];

// Bing wallpapers from posts with 壁纸 tag
site.posts.forEach(function(post) {
  if (post.tags) {
    var isBing = false;
    post.tags.forEach(function(t) { if (t.name === '壁纸') isBing = true; });
    if (!isBing) return;
    // Only take bing posts (not pexels)
    if (post.source_name !== 'Bing') return;
    var imgRegex = /<img[^>]+src="([^"]+)"/g;
    var match, content = post.content;
    while ((match = imgRegex.exec(content)) !== null) {
      wallpaperImages.push({
        title: post.title,
        url: match[1],
        source: 'Bing',
        date: post.date ? post.date.format('YYYY-MM-DD') : ''
      });
    }
  }
});

// Pexels wallpapers from Hexo data (source/_data/wallpapers.json)
if (site.data && site.data.wallpapers && site.data.wallpapers.length) {
  site.data.wallpapers.forEach(function(item) {
    wallpaperImages.push({
      title: item.title || item.photographer + ' photo',
      url: item.url,
      source: 'Pexels',
      photographer: item.photographer,
      photographer_url: item.photographer_url
    });
  });
}
%>

<div class="wallpapers-page">
  <h1 class="page-title">壁纸</h1>
  <p class="page-subtitle">高清壁纸精选 · 共 <span id="wallpaperTotal"><%= wallpaperImages.length %></span> 张</p>

  <div class="wallpaper-grid" id="wallpaperGrid"></div>
  <div class="wallpaper-pagination" id="wallpaperPagination"></div>
</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <div class="lightbox-bg" id="lightboxBg"></div>
  <button class="lightbox-close" id="lightboxClose">&times;</button>
  <button class="lightbox-prev" id="lightboxPrev">‹</button>
  <button class="lightbox-next" id="lightboxNext">›</button>
  <div class="lightbox-content">
    <img id="lightboxImg" src="" alt="">
    <div class="lightbox-info">
      <span id="lightboxTitle"></span>
      <div class="lightbox-actions">
        <a id="lightboxDownload" class="btn-primary" download>下载原图</a>
      </div>
    </div>
  </div>
</div>

<script>
window.__WALLPAPERS__ = <%- JSON.stringify(wallpaperImages) %>;
</script>
<script src="<%= url_for('/js/wallpapers.js') %>"></script>
