<div class="archive-list">
  <h1 class="page-title">归档</h1>
  <% page.posts.each(function(post) {
      var isWallpaper = false;
      if (post.tags) post.tags.forEach(function(t) { if (t.name === '壁纸') isWallpaper = true; });
      if (isWallpaper) return;
    %>
    <div class="archive-item">
      <span class="archive-date"><%= date(post.date, 'YYYY-MM-DD') %></span>
      <a class="archive-link" href="<%= url_for(post.path) %>"><%= post.title %></a>
      <% if (post.source_name) { %>
        <span class="archive-source"><%= post.source_name %></span>
      <% } %>
    </div>
  <% }) %>
</div>

<% if (page.total > 1) { %>
<nav class="pagination">
  <%- paginator({
    prev_text: '« 上一页',
    next_text: '下一页 »'
  }) %>
</nav>
<% } %>